              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "clickhouse-dns",
            "type": "grafana-clickhouse-datasource"
          },
          "rawSql": "SELECT if(qtype = 'A', 'A (IPv4)', 'AAAA (IPv6)') AS Tipo, round(count() / sum(count()) OVER () * 100, 1) AS Percentual FROM dns_telemetry.dns_queries WHERE ts >= $__fromTime AND ts <= $__toTime AND message_type = 'CLIENT_RESPONSE' AND qtype IN ('A', 'AAAA') GROUP BY Tipo",
          "format": 1,
          "refId": "A"
        }
